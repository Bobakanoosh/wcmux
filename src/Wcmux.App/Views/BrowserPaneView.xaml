<UserControl
    x:Class="Wcmux.App.Views.BrowserPaneView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Background="#1E1E1E">
        <Grid.RowDefinitions>
            <RowDefinition Height="28" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Address bar -->
        <Grid Grid.Row="0" Background="#2D2D2D" Padding="4,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button x:Name="BackButton" Grid.Column="0"
                    Width="24" Height="24" MinWidth="0" MinHeight="0"
                    Padding="0" BorderThickness="0"
                    Background="Transparent" IsEnabled="False"
                    Click="OnBackClick">
                <FontIcon Glyph="&#xE72B;" FontSize="12" Foreground="#CCCCCC" />
            </Button>

            <Button x:Name="ForwardButton" Grid.Column="1"
                    Width="24" Height="24" MinWidth="0" MinHeight="0"
                    Padding="0" BorderThickness="0"
                    Background="Transparent" IsEnabled="False"
                    Click="OnForwardClick">
                <FontIcon Glyph="&#xE72A;" FontSize="12" Foreground="#CCCCCC" />
            </Button>

            <Button x:Name="ReloadButton" Grid.Column="2"
                    Width="24" Height="24" MinWidth="0" MinHeight="0"
                    Padding="0" BorderThickness="0"
                    Background="Transparent"
                    Click="OnReloadClick">
                <FontIcon Glyph="&#xE72C;" FontSize="12" Foreground="#CCCCCC" />
            </Button>

            <TextBox x:Name="AddressBox" Grid.Column="3"
                     VerticalAlignment="Center"
                     FontSize="12"
                     PlaceholderText="Enter URL..."
                     Background="#3C3C3C" Foreground="#CCCCCC"
                     BorderThickness="0"
                     Padding="6,2"
                     KeyDown="OnAddressBoxKeyDown">
                <TextBox.Resources>
                    <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="#3C3C3C" />
                    <SolidColorBrush x:Key="TextControlForegroundFocused" Color="#CCCCCC" />
                    <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="#454545" />
                    <SolidColorBrush x:Key="TextControlForegroundPointerOver" Color="#CCCCCC" />
                </TextBox.Resources>
            </TextBox>

            <Button x:Name="GoButton" Grid.Column="4"
                    Width="28" Height="24" MinWidth="0" MinHeight="0"
                    Padding="0" BorderThickness="0"
                    Background="Transparent"
                    Click="OnGoClick">
                <FontIcon Glyph="&#xE7AD;" FontSize="12" Foreground="#CCCCCC" />
            </Button>
        </Grid>

        <!-- WebView2 browser content -->
        <WebView2 x:Name="BrowserWebView" Grid.Row="1"
                  DefaultBackgroundColor="#1E1E1E" />
    </Grid>
</UserControl>
